{
  "$schema": "node_modules/wrangler/config-schema.json",
  "compatibility_date": "2026-05-23",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS"
  },
  
  // Explicit environments configuration
  "env": {
    "dev": {
      "name": "dicethrone-dev"
    },
    "production": {
      "name": "dicethrone-prod"
    }
  }
}